{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CODEX_PROJECT_DIR\"/.codex/hooks/protect-files.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CODEX_PROJECT_DIR\"/.codex/hooks/post-compact-restore.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
